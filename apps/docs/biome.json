{
  "$schema": "https://biomejs.dev/schemas/2.4.8/schema.json",
  "extends": "//",
  "files": {
    "includes": ["**", "!src/route-tree.gen.ts", "!.source"]
  },
  "overrides": [
    {
      "assist": {
        "actions": {
          "source": {
            "useSortedKeys": "off"
          }
        }
      },
      "includes": ["src/app/**/*.tsx", "src/app/**/*.ts"],
      "linter": {
        "rules": {
          "style": {
            "useComponentExportOnlyModules": "off",
            "useFilenamingConvention": "off"
          }
        }
      }
    }
  ],
  "root": false
}
