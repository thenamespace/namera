  "devDependencies": {
    "@biomejs/biome": "2.4.8",
    "@changesets/changelog-github": "^0.6.0",
    "@changesets/cli": "^2.30.0",
    "@changesets/read": "^0.6.7",
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@effect/language-service": "^0.84.3",
    "@effect/platform-bun": "^4.0.0-beta.43",
    "@namera-ai/config": "workspace:*",
    "effect": "^4.0.0-beta.43",
    "lefthook": "^2.1.4",
    "turbo": "^2.8.18",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=18"
  },
  "homepage": "https://github.com/thenamespace/namera#readme",
  "keywords": [],
  "license": "Apache-2.0",
  "name": "namera",
  "packageManager": "bun@1.3.9",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/thenamespace/namera.git"
  },
  "scripts": {
    "build": "turbo build",
    "changeset": "changeset",
    "commitlint": "commitlint --edit",
    "dev": "turbo dev",
    "format": "bunx --bun biome format --write",
    "format:check": "bunx --bun biome format",
    "lint": "bunx --bun biome check --write",
    "lint:check": "bunx --bun biome check",
    "prepare": "lefthook install",
    "release": "bun run build && changeset publish",
    "version": "bun scripts/changelog.ts && changeset version"
  },
  "version": "1.0.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ]
